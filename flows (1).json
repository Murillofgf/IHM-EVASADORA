    {
        "id": "8d9d7136052f8416",
        "type": "function",
        "z": "4ed9602fa02c9a3b",
        "name": "porcentoGarrafas",
        "func": "// 1. Pega a meta de garrafas que você selecionou (salva na memória 'numGarrafas')\nlet metaSeleccionada = flow.get(\"numGarrafas\") || 1;\n\n// 2. Pega quantas garrafas o sensor já contou (valor real vindo do sensor)\nlet totalEnchidas = msg.payload;\n\n// 3. Cálculo da Porcentagem\n// Usamos Math.max(1, ...) para garantir que nunca divida por zero se a meta for 0\nlet porcentagem = (totalEnchidas / Math.max(1, metaSeleccionada)) * 100;\n\n// 4. Formatação para ficar bonito no Gauge (ex: 50.5%)\nmsg.payload = parseFloat(porcentagem.toFixed(1));\n\n// 5. Opcional: Enviar informações extras para um texto no Dashboard\nmsg.topic = \"Progresso da Produção\";\nmsg.status_texto = totalEnchidas + \" de \" + metaSeleccionada + \" garrafas\";\n\nreturn msg;",
