        "z": "4ed9602fa02c9a3b",
        "name": "function 1",
        "func": "// 1. Recupera o estado atual dos botões ou define o padrão inicial\nlet status = flow.get(\"botoes_status\") || { start: true, stop: false, config: false, enviar: false };\n\nlet comando = msg.topic;\n\n// 2. Lógica de transição de estados\nif (comando === \"start\") {\n    status.start = false;\n    status.stop = true;\n    status.config = true;\n    status.enviar = false; // Começa desligado até configurar\n} \nelse if (comando === \"stop\") {\n    status.start = true;\n    status.stop = false;\n    status.config = false;\n    status.enviar = true;\n} \nelse if (comando === \"config\") {\n    // Só permite habilitar o enviar se o Stop estiver ativo (ou seja, o sistema deu Start)\n    if (status.stop === true) {\n        status.enviar = true;\n    }\n}\n\n// 3. Salva o novo estado na memória para o próximo clique\nflow.set(\"botoes_status\", status);\n\n// 4. Envia para as 4 saídas\nreturn [\n    { enabled: status.start },  // Saída 1\n    { enabled: status.stop },   // Saída 2\n    { enabled: status.config }, // Saída 3\n    { enabled: status.enviar }  // Saída 4\n];",
        "outputs": 4,
